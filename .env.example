# x402 facilitator (MVP): hosted OpenZeppelin + Stellar service.
# Docs: https://developers.stellar.org/docs/build/agentic-payments/x402/built-on-stellar
# API key: https://channels.openzeppelin.com/testnet/gen (testnet)

# --- apps/shieldpay-api/.env.local ---
# Base URL of the facilitator (exposes /verify, /settle, /supported in x402 v2)
OZ_RELAYER_URL=https://channels.openzeppelin.com/x402/testnet
OZ_RELAYER_API_KEY=your_key_from_channels_openzeppelin_com
TRUSTLESS_WORK_API_URL=https://api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=your_tw_api_key
TRUSTLESS_WORK_RELEASE_SIGNER=your_stellar_address
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
STELLAR_NETWORK=testnet
SLACK_WEBHOOK_URL=your_slack_webhook

# --- apps/dashboard/.env.local ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- packages/sentinel-sdk --- Soroban governance contract
SENTINEL_CONTRACT_ID=C_your_deployed_contract_id
SENTINEL_OPERATOR_SECRET=S_your_operator_signing_key
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- packages/sentinel-sdk --- Supabase mirror (optional, for dashboard)
# SUPABASE_URL=your_supabase_url
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
