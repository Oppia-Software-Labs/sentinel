{
  "name": "@oppialabs/sentinel-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for Sentinel / ShieldPay: Soroban policy checks, multi-agent consensus, and Supabase mirroring for payment intents.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oppia-Software-Labs/sentinel.git",
    "directory": "packages/sentinel-sdk"
  },
  "keywords": [
    "stellar",
    "soroban",
    "sentinel",
    "shieldpay",
    "consensus"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@stellar/stellar-sdk": "^14.6.1",
    "axios": "^1.7.9",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3"
  }
}
