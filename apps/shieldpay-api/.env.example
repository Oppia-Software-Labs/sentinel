# ── x402 Facilitator (OpenZeppelin) ──────────────────────────────────────────
# Generate testnet key: https://channels.openzeppelin.com/testnet/gen
OZ_RELAYER_URL=https://channels.openzeppelin.com/x402/testnet
OZ_RELAYER_API_KEY=your_key

# ── Trustless Work ────────────────────────────────────────────────────────────
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=your_tw_api_key
# Stellar secret key — signs TW transactions (approver, releaseSigner, etc.)
TRUSTLESS_WORK_RELEASE_SIGNER=S...

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Soroban contract ──────────────────────────────────────────────────────────
SENTINEL_CONTRACT_ID=C...
SENTINEL_OPERATOR_SECRET=S...
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── LLM (logic agent AI voter) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Custom hosted agents ─────────────────────────────────────────────────────
# Secret for encrypting user-provided API keys (generate with: openssl rand -hex 32)
AGENT_KEY_SECRET=

# ── Notifications ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Agent thresholds (optional — these are the defaults) ─────────────────────
RISK_RETRY_STORM_THRESHOLD=5
RISK_VELOCITY_MULTIPLIER=3
COST_DAILY_CAP=500
COST_HOURLY_CAP=100
COST_SINGLE_PAYMENT_CAP=50
MPP_SESSION_KILL_LIMIT=100
LOGIC_SUPPORTED_ASSETS=USDC,USDT,XLM
LOGIC_SUSPICIOUS_VENDORS=