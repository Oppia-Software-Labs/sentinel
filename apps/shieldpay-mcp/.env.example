# ShieldPay API (must be running)
SHIELDPAY_API_URL=http://localhost:4000

# Owner — Stellar G-address, same as NEXT_PUBLIC_OWNER_ID in the dashboard
SHIELDPAY_OWNER_ID=G...

# How Claude identifies itself in transactions (shows up on the dashboard)
SHIELDPAY_AGENT_ID=claude-code

# Supabase (for get_policy and get_transactions tools)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
